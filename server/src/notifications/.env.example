# =============================================================================
# ClearTalk Notification System Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Twilio Configuration (SMS)
# -----------------------------------------------------------------------------
# Get credentials from: https://console.twilio.com/
# Account SID and Auth Token are in Console Dashboard

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Purchase a phone number from: https://console.twilio.com/phone-numbers
# Must be SMS-enabled
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# SendGrid Configuration (Email)
# -----------------------------------------------------------------------------
# Create API key from: https://app.sendgrid.com/settings/api_keys
# Required scopes: Mail Send (Full Access)

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be a verified sender in SendGrid
# Set up sender authentication: https://app.sendgrid.com/settings/sender_auth
SENDGRID_FROM_EMAIL=notifications@cleartalk.com

# Optional: For webhook signature verification
# Get from: https://app.sendgrid.com/settings/mail_settings
SENDGRID_WEBHOOK_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Base URL of your API server (for webhook callbacks)
# Production: https://api.cleartalk.com
# Staging: https://staging-api.cleartalk.com
# Local dev: https://your-ngrok-url.ngrok.io

SERVER_BASE_URL=https://api.cleartalk.com

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database

DATABASE_URL=postgresql://postgres:password@localhost:5432/cleartalk

# -----------------------------------------------------------------------------
# Monitoring & Alerting (Optional)
# -----------------------------------------------------------------------------
# PagerDuty integration key (for critical alerts)
PAGERDUTY_INTEGRATION_KEY=

# Slack webhook URL (for alert notifications)
SLACK_WEBHOOK_URL=

# Sentry DSN (for error tracking)
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum SMS per hour per user (default: 10)
SMS_RATE_LIMIT_PER_HOUR=10

# Maximum push notifications per minute (default: unlimited)
PUSH_RATE_LIMIT_PER_MINUTE=0

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable specific notification channels
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable webhook signature verification (recommended in production)
VERIFY_WEBHOOK_SIGNATURES=true

# Enable notification tracking and analytics
ENABLE_NOTIFICATION_TRACKING=true

# -----------------------------------------------------------------------------
# Development/Testing
# -----------------------------------------------------------------------------
# Test mode - don't actually send notifications, just log them
TEST_MODE=false

# Override recipient for all notifications (for testing)
# TEST_OVERRIDE_EMAIL=test@example.com
# TEST_OVERRIDE_PHONE=+1234567890

# Verbose logging
DEBUG_NOTIFICATIONS=false
